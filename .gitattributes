# Auto-detect text files and normalize line endings to LF in the repo.
* text=auto eol=lf

# Force LF for shell-driven and config files.
*.sh        text eol=lf
*.yml       text eol=lf
*.yaml      text eol=lf

# Force CRLF for Windows-only scripts.
*.ps1       text eol=crlf
*.bat       text eol=crlf
*.cmd       text eol=crlf

# Treat as binary (no diff, no EOL conversion).
*.png       binary
*.jpg       binary
*.jpeg      binary
*.gif       binary
*.webp      binary
*.ico       binary
*.woff      binary
*.woff2     binary
*.ttf       binary
*.otf       binary
*.eot       binary
*.zip       binary

# Files to exclude from GitHub language stats and from `git archive` exports.
node_modules/   export-ignore
vendor/         export-ignore
dist/           export-ignore
.github/        export-ignore
.gitattributes  export-ignore
.gitignore      export-ignore
